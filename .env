# Development Environment Variables
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:3000/graphql
DEBUG=true
NEXT_PUBLIC_ENABLE_GRID_EXPOSER=true

# Production Environment Variables
# NODE_ENV=production
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://api.yourdomain.com/graphql
# DEBUG=false
# NEXT_PUBLIC_ENABLE_GRID_EXPOSER=false

# Shared Environment Variables
NEXT_PUBLIC_APP_NAME=Your App Name
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# DatoCMS
NEXT_DATOCMS_API_TOKEN=CHANGE_ME
DATOCMS_PUBLISHED_CONTENT_CDA_TOKEN=your_published_token_here
DATOCMS_DRAFT_CONTENT_CDA_TOKEN=your_draft_token_here
DATOCMS_API_TOKEN=your_full_access_token_here
SECRET_API_TOKEN=your_secret_webhook_token_here
DRAFT_MODE_SECRET=run_openssl_rand_hex_32
DATOCMS_BASE_EDITING_URL=https://your-project.admin.datocms.com/environments/main
