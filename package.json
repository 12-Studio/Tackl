{
	"name": "tackl",
	"version": "3.3.0",
	"description": "The ultimate Next.js starter kit!",
	"license": "MIT",
	"packageManager": "bun@1.3.9",
	"engines": {
		"node": ">=24.0.0"
	},
	"author": "joebentaylor1995",
	"repository": {
		"type": "git",
		"url": "https://github.com/12-studio/tackl"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build --webpack",
		"start": "next start",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"type-check": "tsc --noEmit",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"serve": "serve ./out",
		"commit": "node .gitmessage.js",
		"postinstall": "husky",
		"test": "echo \"No tests specified\" && exit 0",
		"lighthouse": "lhci autorun",
		"outdated": "bunx npm-check-updates",
		"sanity:cors": "sanity cors add http://localhost:3000 --credentials",
		"sanity:cors:production": "sanity cors add https://sanity--tackl.netlify.app --credentials"
	},
	"dependencies": {
		"@datocms/cda-client": "^0.2.10",
		"@gsap/react": "^2.1.2",
		"@portabletext/react": "^6.2.0",
		"@portabletext/types": "^4.0.2",
		"@sanity/image-url": "^2.1.1",
		"@sanity/vision": "5",
		"color": "^5.0.3",
		"graphql": "^16.12.0",
		"graphql-tag": "^2.12.6",
		"gsap": "^3.14.2",
		"lenis": "^1.3.17",
		"next": "^16.1.6",
		"next-sanity": "^13.0.8",
		"picocolors": "^1.1.1",
		"prompts": "^2.4.2",
		"react": "^19.2.4",
		"react-datocms": "^7.2.14",
		"react-dom": "^19.2.4",
		"sanity": "^5.28.0",
		"server-only": "^0.0.1",
		"styled-components": "6",
		"tar": "^7.5.9",
		"unicornstudio-react": "^2.0.1"
	},
	"devDependencies": {
		"@lhci/cli": "^0.15.1",
		"@storybook/addon-docs": "^10.2.10",
		"@storybook/addon-links": "^10.2.10",
		"@storybook/addon-onboarding": "^10.2.10",
		"@storybook/addon-themes": "^10.2.10",
		"@storybook/nextjs": "^10.2.10",
		"@types/node": "^25.3.0",
		"@types/react": "^19.2.14",
		"@biomejs/biome": "^2.4.4",
		"ajv": "^8.18.0",
		"ajv-keywords": "^5.1.0",
		"husky": "^9.1.7",
		"storybook": "^10.2.10",
		"typescript": "5.9.3"
	},
	"husky": {
		"hooks": {
			"pre-commit": "bun run commit"
		}
	}
}
